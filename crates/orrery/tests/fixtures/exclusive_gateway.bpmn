<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  targetNamespace="http://orrery.dev/test"
  id="Definitions_1">
  <bpmn:process id="gw-process" isExecutable="true">
    <bpmn:startEvent id="start">
      <bpmn:outgoing>sf1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="sf1" sourceRef="start" targetRef="gw1"/>
    <bpmn:exclusiveGateway id="gw1">
      <bpmn:outgoing>sf2</bpmn:outgoing>
      <bpmn:outgoing>sf3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="sf2" sourceRef="gw1" targetRef="task_a">
      <bpmn:conditionExpression>approved == true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="sf3" sourceRef="gw1" targetRef="task_b"/>
    <bpmn:serviceTask id="task_a">
      <bpmn:outgoing>sf4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="task_b">
      <bpmn:outgoing>sf5</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="sf4" sourceRef="task_a" targetRef="end"/>
    <bpmn:sequenceFlow id="sf5" sourceRef="task_b" targetRef="end"/>
    <bpmn:endEvent id="end"/>
  </bpmn:process>
</bpmn:definitions>
